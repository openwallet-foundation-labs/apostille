# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
/dist
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files - NEVER commit actual secrets
.env
.env.*
.env.local
.env.*.local
!.env.example

# Kubernetes secrets - use templates instead
*-secret.yaml
*-secrets.yaml
!*-secret.yaml.template
!*-secrets.yaml.template

# Private keys and certificates
*.key
*.p12
*.pfx
credentials.json
service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/did-kanon
/kanon_contractsk8s/local/secrets.yaml
k8s/local/secrets.yaml
k8s/
