# ============================================================================
# Apostille Environment Configuration
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in all required values.
# NEVER commit .env files with real credentials to version control.
# ============================================================================

# ============================================================================
# REQUIRED - Application will NOT start without these
# ============================================================================

# Database Configuration
# ----------------------
# PostgreSQL connection credentials - MUST be set explicitly
POSTGRES_PASSWORD=your-secure-database-password-here
DB_USER=postgres
DB_NAME=verifiable_ai
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=allow
DATABASE_URL=postgresql://${DB_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Authentication
# --------------
# JWT secret for signing tokens - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters

# Wallet Configuration
# --------------------
# Main wallet credentials for the Credo agent
MAIN_WALLET_ID=main-wallet
MAIN_WALLET_KEY=your-secure-wallet-key-here

# ============================================================================
# NETWORKING - Required for deployment
# ============================================================================

# API/Agent Endpoints
PORT=3002
AGENT_PORT=3003
AGENT_WS_PORT=3004

# Public URLs - Set to your deployment domain
AGENT_ENDPOINT=http://localhost:3003
API_URL=http://localhost:3002
PUBLIC_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# DID Web Domain (for did:web DIDs)
# Set to your production API domain without protocol (e.g., api.example.com)
DID_WEB_DOMAIN=localhost:3002

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# OPTIONAL - Features disabled if not set
# ============================================================================

# Redis (Required for horizontal scaling)
# ---------------------------------------
# If not set, falls back to in-memory (single pod only)
# REDIS_URL=redis://localhost:6379

# Database Pool Size (for horizontal scaling)
# DB_POOL_SIZE=10

# Agent Session Timeout (ms)
# AGENT_SESSION_TIMEOUT=15000

# Platform Tenant ID
# ------------------
# Required for demo features and automatic badge issuance
# Create a tenant first, then set this to its UUID
# PLATFORM_TENANT_ID=

# Blockchain Integration
# ----------------------
# Required for POE (Proof of Existence) features
# ETHEREUM_RPC_URL=https://eth-sepolia-public.unifra.io
# ETHEREUM_PRIVATE_KEY=your-ethereum-private-key

# Vault Storage (S3)
# ------------------
# Required for encrypted vault storage (large files)
# S3_VAULT_BUCKET=apostille-vaults
# S3_VAULT_REGION=us-east-1
# S3_VAULT_ACCESS_KEY_ID=your-s3-access-key-id
# S3_VAULT_SECRET_ACCESS_KEY=your-s3-secret-access-key
# S3_VAULT_ENDPOINT=  # Optional: Custom endpoint for MinIO/Cloudflare R2

# WebRTC TURN Server
# ------------------
# Required for peer-to-peer video/audio
# WEBRTC_TURN_AUTH_SECRET=your-64-char-random-secret
# WEBRTC_TURN_CRED_TTL_SECONDS=3600
# WEBRTC_TURN_REALM=verifiable-ai
# WEBRTC_STUN_URLS=stun:your-turn-server:3478,turn:your-turn-server:3478,turn:your-turn-server:3478?transport=tcp

# DigiLocker Integration (India only)
# ------------------------------------
# DIGILOCKER_CLIENT_ID=
# DIGILOCKER_CLIENT_SECRET=
# DIGILOCKER_REDIRECT_URI=http://localhost:3002/api/digilocker/callback

# Email Service (Mailgun)
# -----------------------
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# Issuer Configuration
# --------------------
# ISSUER_NAME=Your Organization
# ISSUER_URL=http://localhost:3000

# MDL (Mobile Driver License) Certificates
# -----------------------------------------
# MDL_USE_TEST_CERTIFICATES=true
# MDL_ISSUER_CERT_PATH=
# MDL_ISSUER_KEY_PATH=
# MDL_IACA_CERT_PATH=
# MDL_SIGNING_ALGORITHM=ES256

# WebSocket Configuration
# -----------------------
# WS_PATH=/ws
# WS_PING_INTERVAL_MS=30000

# Notification Types (comma-separated)
# NOTIFICATION_TYPES=

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3002
# NEXT_PUBLIC_COMPANY_NAME=Your Company
# NEXT_PUBLIC_COMPANY_LOGO_URL=

# ============================================================================
# DEVELOPMENT/DEBUG
# ============================================================================

NODE_ENV=development
# DB_SSL_MODE=disable
