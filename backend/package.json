{
  "name": "apostille-backend",
  "version": "1.0.0",
  "description": "Express backend for Apostille",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:redis": "jest --testPathPattern=redis",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:integration:watch": "jest --testPathPattern=integration --runInBand --watch",
    "test:integration:api": "jest --testPathPattern='api.integration' --runInBand",
    "test:integration:connections": "jest --testPathPattern='connection-flow' --runInBand",
    "test:integration:did-schema": "jest --testPathPattern='did-schema' --runInBand",
    "test:integration:credentials": "jest --testPathPattern='credential-flow' --runInBand",
    "test:integration:oid4vc": "jest --testPathPattern='oid4vc' --runInBand",
    "test:integration:all-apis": "jest --testPathPattern='all-apis' --runInBand",
    "test:live": "TEST_API_URL=${TEST_API_URL:-http://localhost:30002} jest --testPathPattern=integration --runInBand",
    "test:live:quick": "TEST_API_URL=${TEST_API_URL:-http://localhost:30002} jest --testPathPattern='all-apis' --runInBand -t 'Quick API Health Check'",
    "test:all": "jest",
    "migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "@ajna-inc/group-messaging": "0.1.2",
    "@ajna-inc/openbadges": "0.1.13",
    "@ajna-inc/payments": "^0.5.17",
    "@ajna-inc/poe": "0.0.4",
    "@ajna-inc/signing": "0.1.6",
    "@ajna-inc/vaults": "0.1.1",
    "@ajna-inc/webrtc": "0.2.1",
    "@ajna-inc/workflow": "0.5.37",
    "@ajna-inc/workflow-backend-express": "workspace:*",
    "@aws-sdk/client-s3": "^3.966.0",
    "@aws-sdk/s3-request-presigner": "^3.966.0",
    "@credo-ts/anoncreds": "0.5.17",
    "@credo-ts/askar": "0.5.17",
    "@credo-ts/cheqd": "0.5.17",
    "@credo-ts/core": "0.5.17",
    "@credo-ts/indy-vdr": "0.5.17",
    "@credo-ts/node": "0.5.17",
    "@credo-ts/openid4vc": "0.5.17",
    "@credo-ts/tenants": "0.5.17",
    "@hyperledger/anoncreds-nodejs": "^0.3.1",
    "@hyperledger/anoncreds-shared": "^0.3.1",
    "@hyperledger/aries-askar-nodejs": "^0.2.3",
    "@openwallet-foundation/askar-nodejs": "^0.4.1",
    "@openwallet-foundation/askar-shared": "^0.4.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "buffer": "^6.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "email-validator": "^2.0.4",
    "ethers": "^6.13.7",
    "express": "4.20.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
